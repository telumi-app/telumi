{
  "name": "@telumi/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "prisma migrate deploy && node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@fastify/static": "7",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.18.0",
    "@telumi/db": "workspace:*",
    "@telumi/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "fastify": "^4.28.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@telumi/eslint-config": "workspace:*",
    "@telumi/tsconfig": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "prisma": "^5.18.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
